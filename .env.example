DJANGO_DEBUG=1
WEB_SERVICE_PORT=8000
DJANGO_SECRET_KEY=django-local-development-secret-key-2026
JWT_SECRET_KEY=jwt-local-development-secret-key-2026-long
INTERNAL_SERVICE_TOKEN=internal-local-service-token-2026

STAFF_SERVICE_PORT=8001
CUSTOMER_SERVICE_PORT=8002
CLOTH_SERVICE_PORT=8003
LAPTOP_SERVICE_PORT=8004
MOBILE_SERVICE_PORT=8005
CHATBOT_SERVICE_PORT=8006
ACCESSORY_SERVICE_PORT=8007
HOME_APPLIANCE_SERVICE_PORT=8008
BOOK_SERVICE_PORT=8009
BEAUTY_SERVICE_PORT=8010
FOOD_SERVICE_PORT=8011
SPORTS_SERVICE_PORT=8012
GAMING_SERVICE_PORT=8013
BEHAVIOR_SERVICE_PORT=8014
RECOMMENDATION_SERVICE_PORT=8015

# --- LLM Provider (chatbot-service) ---
# Ưu tiên dùng OpenAI nếu có key, nếu không tự động fallback sang Gemini.
# Gemini miễn phí hoàn toàn: https://aistudio.google.com/apikey
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gemini (miễn phí, không cần credit card)
# Nếu gemini-2.0-flash báo quota/limit:0, dùng gemini-1.5-flash
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-1.5-pro

# Set to 1 to enable embedding-based retrieval (requires OPENAI_API_KEY)
USE_EMBEDDING_RETRIEVAL=0
# Number of KB chunks to retrieve per question
KB_RETRIEVAL_TOP_K=5
# Number of conversation turns to include as context
CONVERSATION_HISTORY_LIMIT=6

